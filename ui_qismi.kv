<ScreenManager>:
    Oyna:
        name: 'Oyna'
    Oyna1:
        name: 'Oyna1'


<Oyna>:
    canvas.before:
        Color:
            rgba: 0.1, 0.5, 0.2, 1
        Rectangle:
            size: self.size
            pos: self.pos
    
    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 10
        
        Label:
            text: "Ishlash vaqtini kiriting"
            font_size: '24sp'
        TextInput:
            id: ol_ish
            size_hint: (1, None)
            height: '50dp'  # Balandlikni belgilash muhim
            hint_text: "000 min"
            multiline: False
            input_filter: "int"
            font_size: '28sp'
            foreground_color: 0, 1, 0, 1
            cursor_color: 0, 1, 0, 1
        
        Label:
            text: "Dam olish vaqtini kiriting"
            font_size: '24sp'
        TextInput:
            id: ol_dam
            size_hint: (1, None)
            height: '50dp'
            hint_text: "000 min"
            font_size: '28sp'
            multiline: False
            input_filter: "int"
            padding: [20, 6, 10, 2]
            foreground_color: 1, 0, 0, 1
            cursor_color: 1, 0, 0, 1
            write_tab: False
            
        Widget: # Bo'sh joy qo'shish uchun
        
        Button:
            text: "Saqlash"
            pos_hint: {"center_x": 0.5}
            size_hint: (1, 0.5)
            #width: 500
            #height: 10
            font_name: 'Roboto-Bold.ttf'
            font_size: '40sp'
            bold: True
            color: 0, 1, 0, 1
            background_color: 21/255, 82/255, 39/255, 1
            background_normal: ''
            on_press: root.ornatildi()

<Oyna1>:
    canvas.before:
        Color:
            rgba: 4/255, 116/255, 0/255, 1
        Rectangle:
            size: self.size
            pos: self.pos
            
    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 20
        
        Label:
            id: matn
            text: "00:00:00"
            font_size: '60sp'
            font_name: 'font2.ttf'
            color: 0, 1, 0, 1
        Label:
            id: matn1
            text: "00:00:00"
            font_size: '60sp'
            font_name: 'font2.ttf'
            color: 1, 0, 0, 1
            
        Button:
            id: btn
            text: "Start"
            pos_hint: {"center_x": 0.5}
            size_hint: (1, 0.3)
            #width: 500
            #height: 10
            font_name: 'Roboto-Bold.ttf'
            font_size: '50sp'
            bold: True
            color: 0, 1, 0, 1
            background_color: 21/255, 82/255, 39/255, 1
            background_normal: ''
            on_release: root.toggle_timer()